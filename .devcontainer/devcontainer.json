// Hermes Cloud Codespace — 24/7 Telegram gateway runner
// Codespaces secrets TELEGRAM_BOT_TOKEN and GH_TOKEN_FOR_API
// are set at the repo level and become env vars automatically.
{
  "name": "Hermes Cloud Gateway",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "8gb"
  },
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteEnv": {
    "TELEGRAM_BOT_TOKEN": "${secrets:TELEGRAM_BOT_TOKEN}",
    "GH_TOKEN_FOR_API": "${secrets:GH_TOKEN_FOR_API}"
  },
  "postCreateCommand": "bash .devcontainer/setup-hermes.sh",
  "postStartCommand": "bash .devcontainer/start-gateway.sh",
  "postAttachCommand": "cat ~/.hermes/cloud-setup-done 2>/dev/null && bash .devcontainer/post-attach.sh || echo '⏳ Setup still running...'",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Hermes Gateway",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": ["ms-python.python"]
    }
  }
}
